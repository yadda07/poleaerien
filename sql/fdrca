-- FUNCTION: rip_avg_nge.fdrca(text)

-- DROP FUNCTION IF EXISTS rip_avg_nge.fdrca(text);

CREATE OR REPLACE FUNCTION rip_avg_nge.fdrca(
	zasro text)
    RETURNS TABLE(gid_dc bigint, gid integer, sro character varying, nro character varying, length double precision, cab_type character varying, cab_capa integer, cab_modulo bigint, isole character varying, date_modif timestamp with time zone, modif_par character varying, geom geometry, cab_nature character varying, commentaire character varying, collecte character varying, cb_etiquet character varying, fon character varying, projet character varying, "DCE" character varying, dist_type text, affectation character varying) 
    LANGUAGE 'plpgsql'
    COST 100
    VOLATILE PARALLEL UNSAFE
    ROWS 1000

AS $BODY$
DECLARE
    r RECORD;
    start_point geometry;
    end_point geometry;
    new_geom geometry;
    cable_length double precision;
BEGIN
    DROP TABLE IF EXISTS t1;
    CREATE TEMP TABLE t1 AS
    SELECT * FROM rip_avg_nge.FDDCPFA(zasro, 1);
    FOR r IN (SELECT * FROM t1) LOOP
        IF r.geom IS NULL OR NOT ST_IsValid(r.geom) THEN
            CONTINUE;
        END IF;

        start_point := ST_StartPoint(r.geom);
        end_point := ST_EndPoint(r.geom);

        IF (SELECT COUNT(*) FROM rip_avg_nge.attaches t2 
            WHERE ST_Intersects(start_point, t2.geom) 
            AND t2.sro ILIKE '%' || zasro || '%') > 0 THEN
            start_point := (SELECT ST_StartPoint(t2.geom) 
                            FROM rip_avg_nge.attaches t2 
                            WHERE ST_Intersects(start_point, t2.geom) 
                            AND t2.sro ILIKE '%' || zasro || '%' 
                            ORDER BY ST_Distance(start_point, t2.geom) LIMIT 1);
        END IF;
        IF (SELECT COUNT(*) FROM rip_avg_nge.attaches t2 
            WHERE ST_Intersects(end_point, t2.geom) 
            AND t2.sro ILIKE '%' || zasro || '%') > 0 THEN
            end_point := (SELECT ST_StartPoint(t2.geom) 
                          FROM rip_avg_nge.attaches t2 
                          WHERE ST_Intersects(end_point, t2.geom) 
                          AND t2.sro ILIKE '%' || zasro || '%' 
                          ORDER BY ST_Distance(end_point, t2.geom) LIMIT 1);
        END IF;

        new_geom := ST_SetPoint(ST_SetPoint(r.geom, 0, start_point), ST_NumPoints(r.geom) - 1, end_point);

        cable_length := ST_Length(new_geom);

        IF cable_length > 0.2 THEN
            UPDATE t1 SET geom = new_geom WHERE t1.gid_dc = r.gid_dc;
        ELSE
            DELETE FROM t1 WHERE t1.gid_dc = r.gid_dc;  
        END IF;
    END LOOP;

    DELETE FROM t1
    WHERE t1.ctid IN (
        SELECT t1.ctid
        FROM (
            SELECT t1.ctid, ROW_NUMBER() OVER (PARTITION BY t1.gid, md5(ST_AsText(t1.geom)) ORDER BY t1.gid) AS rnum
            FROM t1
        ) sub
        WHERE sub.rnum > 1
    );
    RETURN QUERY SELECT * FROM t1 WHERE ST_Length(t1.geom) > 0.2;  
END;
$BODY$;

