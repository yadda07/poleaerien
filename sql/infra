-- FUNCTION: rip_avg_nge.infra(text)

-- DROP FUNCTION IF EXISTS rip_avg_nge.infra(text);

CREATE OR REPLACE FUNCTION rip_avg_nge.infra(
	zasro text)
    RETURNS TABLE(gid integer, gid_pt text, sro character varying, nro character varying, inf_type character varying, inf_num character varying, inf_mat character varying, inf_propri character varying, adr_ville character varying, adr_insee numeric, adr_cp numeric, noe_usage character varying, noe_codext character varying, isole numeric, date_modif timestamp without time zone, modif_par character varying, geom geometry, collecte character varying, dce character varying, affectation character varying) 
    LANGUAGE 'plpgsql'
    COST 100
    VOLATILE PARALLEL UNSAFE
    ROWS 1000

AS $BODY$
BEGIN
    RETURN QUERY 
    WITH tmp1 AS (
        SELECT 
            'pot_' || p.gid AS gid_pt, 
            p.sro, 
            p.nro, 
            p.inf_type, 
            p.inf_num, 
            p.inf_mat, 
            p.inf_propri, 
            p.adr_ville, 
            p.adr_insee, 
            p.adr_cp, 
            p.noe_usage, 
            p.noe_codext, 
            cast(p.isole as numeric), 
            p.date_modif, 
            p.modif_par, 
            p.geom, 
            p.collecte, 
            p.dce, 
            p.affectation
        FROM rip_avg_nge.infra_pt_pot  p where p.sro ILIKE '%'|| zasro ||'%'
        UNION 
        SELECT 
            'chb_' || c.gid AS gid_pt, 
            c.sro, 
            c.nro, 
            c.inf_type, 
            c.inf_num, 
            c.inf_mat, 
            c.inf_propri, 
            c.adr_ville, 
            c.adr_insee, 
            c.adr_cp, 
            c.noe_usage, 
            c.noe_codext, 
            cast(c.isole as numeric),
            c.date_modif, 
            c.modif_par, 
            c.geom, 
            c.collecte, 
            c.dce, 
            c.affectation
        FROM rip_avg_nge.infra_pt_chb c where  c.sro ILIKE '%'|| zasro ||'%'
        UNION
        SELECT 
            'atr_' || a.gid AS gid_pt, 
            a.sro, 
            a.nro, 
            a.inf_type, 
            a.inf_num, 
            a.inf_mat, 
            a.inf_propri, 
            a.adr_ville, 
            a.adr_insee, 
            a.adr_cp, 
            a.noe_usage, 
            a.noe_codext, 
            a.isole, 
            a.date_modif, 
            a.modif_par, 
            a.geom, 
            a.collecte, 
            a.dce, 
            a.affectation
        FROM rip_avg_nge.infra_pt_autres a where a.sro ILIKE '%'|| zasro ||'%'
    )
    SELECT ROW_NUMBER() OVER ()::integer AS gid, * FROM tmp1;
END;
$BODY$;

ALTER FUNCTION rip_avg_nge.infra(text)
    OWNER TO ownergrp_auvergne;

GRANT EXECUTE ON FUNCTION rip_avg_nge.infra(text) TO PUBLIC;

